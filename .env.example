APP_NAME=BBVA Knowledge Assistant
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/app.db
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=bbva_website
OLLAMA_URL=http://ollama:11434
CHAT_MODEL=llama3.2:1b
EMBEDDING_MODEL=nomic-embed-text
HISTORY_WINDOW=6
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=6
RERANK_TOP_K=3
SCRAPE_BASE_URL=https://www.bbva.com/es/co/
SCRAPE_PATH_PREFIX=/es/co/
SCRAPE_MAX_PAGES=30
SCRAPE_DELAY_SECONDS=0.5
REQUEST_TIMEOUT_SECONDS=20
ALLOWED_DOMAINS=bbva.com,www.bbva.com
