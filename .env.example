SCRAPE_PATH_PREFIX=/
SCRAPE_MAX_PAGES=1500
SCRAPE_CONCURRENCY=3
SCRAPE_DELAY_SECONDS=0.5
REQUEST_TIMEOUT_SECONDS=20
